# Copy to .env and adjust. All values have sane defaults for local dev.

# App
PROJECT_NAME=SwiftShip
ENVIRONMENT=development

# Database (async SQLAlchemy URL)
DATABASE_URL=sqlite+aiosqlite:///./swiftship.db

# Security — CHANGE THIS in production (openssl rand -hex 32)
SECRET_KEY=dev-secret-change-me-please-0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# First admin created automatically on startup if it does not exist
FIRST_ADMIN_EMAIL=admin@swiftship.io
FIRST_ADMIN_PASSWORD=admin12345
